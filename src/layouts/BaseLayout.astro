---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Portfolio von Torsten Günter – Online Marketing & E-Commerce Manager mit technischer DNA. Fokus auf CRM, Customer Experience und KI-gestützte Automation.' } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}

    {/* TODO: Diese noindex/nofollow Meta-Tags ENTFERNEN, sobald die .de-Domain live ist.
        Stand: aktuell aktiv, weil die Netlify-Subdomain nicht in den Suchindex soll. */}
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    {/* TODO: og:url und og:image-/twitter:image-URLs auf https://torsten-guenter.de/...
        umstellen, sobald die .de-Domain live ist (Suchen & Ersetzen für die Netlify-URL). */}
    <!-- Open Graph (LinkedIn, Facebook, WhatsApp, Slack, etc.) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Torsten Günter — Portfolio" />
    <meta property="og:title" content="Marketing &amp; E-Commerce mit technischer DNA." />
    <meta property="og:description" content="Portfolio von Torsten Günter – Online Marketing &amp; E-Commerce Manager. Fokus auf CRM, Customer Experience und KI-gestützte Automation." />
    <meta property="og:image" content="https://torsten-guenter.netlify.app/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="627" />
    <meta property="og:image:alt" content="Torsten Günter – Portfolio. Marketing &amp; E-Commerce mit technischer DNA." />
    <meta property="og:url" content="https://torsten-guenter.netlify.app/" />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Marketing &amp; E-Commerce mit technischer DNA." />
    <meta name="twitter:description" content="Portfolio von Torsten Günter – Online Marketing &amp; E-Commerce Manager. Fokus auf CRM, Customer Experience und KI-gestützte Automation." />
    <meta name="twitter:image" content="https://torsten-guenter.netlify.app/og-image.png" />

    <!--
      Fonts: Fraunces (Serif-Überschriften) + Inter (Sans-UI/Fließtext)
      werden self-hosted via Fontsource geladen – siehe src/styles/global.css.
      Kein Request an Google.
    -->

    <title>{title}</title>

    {/* TODO: Bei Domain-Umzug auf torsten-guenter.de im Plausible-Dashboard die
        Site-Konfiguration prüfen (ggf. Domain umstellen oder neue Site anlegen).
        Der Script-Pfad pa-LZdE3zo742iiKCInZsgyI.js ist site-spezifisch und könnte
        sich dann ändern. is:inline verhindert, dass Astro den Snippet bundlet. */}
    <!-- Privacy-friendly analytics by Plausible -->
    <script is:inline async src="https://plausible.io/js/pa-LZdE3zo742iiKCInZsgyI.js"></script>
    <script is:inline>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init({
        outboundLinks: true,
        fileDownloads: true,
        hashBased: false
      })
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-background text-text-primary font-sans antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
