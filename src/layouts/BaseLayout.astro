---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Portfolio von Torsten Günter – Softwareentwickler' } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}

    {/* TODO: Diese noindex/nofollow Meta-Tags ENTFERNEN, sobald die .de-Domain live ist.
        Stand: aktuell aktiv, weil die Netlify-Subdomain nicht in den Suchindex soll. */}
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!--
      Fonts: Fraunces (Serif-Überschriften) + Inter (Sans-UI/Fließtext)
      werden self-hosted via Fontsource geladen – siehe src/styles/global.css.
      Kein Request an Google.
    -->

    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-background text-text-primary font-sans antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
