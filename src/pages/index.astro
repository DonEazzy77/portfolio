---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Torsten Günter – Portfolio"
  description="Portfolio von Torsten Günter – Softwareentwickler und Berater."
>
  <!-- Platzhalter-Hero: wird im nächsten Schritt durch echte Inhalte ersetzt -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <p class="text-sm font-medium text-text-secondary tracking-wide mb-4">Platzhalter</p>
    <h1 class="font-serif text-5xl text-text-primary mb-6 leading-tight">
      Startseite – Inhalt folgt
    </h1>
    <p class="text-text-secondary text-lg max-w-xl leading-relaxed">
      Das Layout-Skelett steht. Navigation, Footer und Design-System sind aktiv.
      Die eigentlichen Inhalte kommen im nächsten Schritt.
    </p>
  </section>
</BaseLayout>
