---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import torstenImage from '../assets/images/torsten.jpeg';

const hasRealPhoto = true;

interface Station {
  period: string;
  title: string;
  company: string | null;
  description: string;
  bullets: string[];
}

interface Value {
  title: string;
  body: string;
}

interface EducationStation {
  period: string;
  title: string;
  institution: string;
  description: string;
}

// Werdegang – reverse chronologisch (neueste Station zuerst)
const stations: Station[] = [
  {
    period: '2024 – heute',
    title: 'Weiterbildung · Neuorientierung',
    company: null,
    description: 'Bewusste Phase der Vertiefung und Erweiterung — fachlich und in der Toolchain.',
    bullets: [
      'Laufendes Studium zum CRM-Manager (IHK) mit Abschluss 2026',
      'Vertiefung in datengetriebene Customer Experience und Marketing-Automation',
      'Aktiver Aufbau einer modernen Toolchain mit KI-gestützten Workflows (Claude, Multi-Agent-Systeme, Prompt Engineering)',
      'Systematische Integration von KI in Marketing- und Entwicklungs-Prozesse',
    ],
  },
  {
    period: '2022 – 2024',
    title: 'Online Marketing & E-Commerce Manager',
    company: 'Pull Up Case',
    description: 'Verantwortlich für den digitalen Auftritt der Marke Pull Up Case in B2C und B2B (Sample Cases), im internationalen E-Commerce-Umfeld.',
    bullets: [
      'Gesamtverantwortung für mehrere Online-Shops und Multichannel-Vertriebskanäle (B2B & B2C)',
      'Steuerung der Performance-Marketing-Aktivitäten (SEA, Social Ads, E-Mail) inkl. Conversion- und Kundenbindungs-Optimierung',
      'Konzeption und Umsetzung kreativer Kampagnen für Digital und Print, in enger Abstimmung mit externen Agenturen',
      'Internationale Zusammenarbeit in englischsprachigen Teams',
    ],
  },
  {
    period: '2021 – 2022',
    title: 'Berufliche Neuorientierung',
    company: null,
    description: 'Marktbeobachtung und Reflektion der eigenen Karriereschwerpunkte vor dem Einstieg bei Pull Up Case.',
    bullets: [],
  },
  {
    period: '2017 – 2021',
    title: 'E-Commerce Manager',
    company: 'Intersport Stähle',
    description: 'Aufbau und Weiterentwicklung des E-Commerce-Bereichs mit Verantwortung für alle digitalen Vertriebskanäle.',
    bullets: [
      'Gesamtverantwortung für E-Commerce und Multichannel-Plattformen',
      'Strategische und operative Steuerung von SEO- und SEA-Maßnahmen',
      'Schnittstelle zwischen Marketing, IT und externen Agenturen für die Umsetzung digitaler Projekte',
      'Analyse und Optimierung von Online-Marketing-Kampagnen und Nutzerverhalten',
      'Übergreifende technische Verantwortung für angrenzende IT-Themen: Kassensysteme, Geräte-Beschaffung und technischer Support im Filial-Umfeld',
    ],
  },
  {
    period: '2014 – 2017',
    title: 'Freelancer im Bereich E-Commerce & Online-Marketing',
    company: null,
    description: 'Nach Standortwechsel von Ludwigsburg zurück in den Schwarzwald: Aufbau einer selbstständigen Beratungs- und Umsetzungstätigkeit für Unternehmen verschiedener Branchen — mit einer 6-monatigen Vollzeit-Unterbrechung durch das Engagement bei WAHL GmbH (siehe folgende Station).',
    bullets: [
      'Strategie- und Konzeptberatung im E-Commerce und Online-Marketing',
      'Konzeption und Umsetzung von SEO- und SEA-Strategien für Industrieunternehmen',
      'Frontend-Entwicklung und technische Umsetzung von Webprojekten',
      'Berufsbegleitende Weiterbildung zum Geprüften Fachkaufmann für Marketing (IHK), 2016-2018',
    ],
  },
  {
    period: '11/2014 – 04/2015',
    title: 'Marketing-Praktikum · befristete Vollzeit-Anstellung',
    company: 'WAHL GmbH, Unterkirnach (internationaler Premium-Hersteller für Profi-Haarschneidemaschinen)',
    description: 'Sechs Monate Vollzeit-Engagement: 3 Monate Marketing-Praktikum mit strategischem Schwerpunkt, gefolgt von 3 Monaten befristeter Anstellung mit operativem Fokus.',
    bullets: [
      'Eigenständige Markt-Segmentierung des Friseurmarkts erstellt, vor der Geschäftsführung präsentiert und in die strategische Planung übernommen',
      'Online-Marketing: SEO-Analysen, Social Ads (Facebook, Google Adwords), Webseiten-Pflege und Content-Distribution',
      'Frontend-/Backend-Fehlersuche, technische Dokumentation, Gewinnspiel-Konzeption und -Auswertung',
      'Überarbeitung des YouTube-Channels, Konzeption von Facebook-Content',
    ],
  },
  {
    period: '2007 – 2012',
    title: 'Multimedia-Entwickler & Online-Marketing',
    company: 'Mediacluster GmbH',
    description: 'Mein technisches Fundament — vom Frontend zum Online-Marketing.',
    bullets: [
      'Frontend-Entwicklung und technische Umsetzung von Webprojekten und digitalen Kampagnen',
      'Konzeption und operative Umsetzung von SEO-, SEA- und Social-Media-Maßnahmen',
      'Mitwirkung am Aufbau des Tochterunternehmens „OnlineAffairs" mit Fokus auf Social-Media-Strategien',
      'Weiterentwicklung des unternehmenseigenen CMS-Systems sowie Realisierung von Digital-Signage-Lösungen mit Hardwareintegration',
    ],
  },
];

const values: Value[] = [
  {
    title: 'Schnittstelle mit Doppelwissen',
    body: 'Mein größter Wert entsteht dort, wo zwei Welten sich von alleine selten treffen — Marketing und IT, Strategie und Code, Mensch und System. Ich übersetze, vermittle, erkläre — und lerne in beiden Welten weiter. Wenn am Ende beide Seiten einander besser verstehen, war es ein guter Tag.',
  },
  {
    title: 'Substanz statt Buzzword-Bingo',
    body: 'Marketing ist kein Zauber, es ist Handwerk. Ich rede lieber Klartext über das, was wirklich funktioniert — und auch über das, was nicht funktioniert. Aufgeblasene Schlagworte ohne Inhalt sind mir genauso suspekt wie Tools, die niemand braucht.',
  },
  {
    title: 'Kreativ und technisch geerdet',
    body: 'Ich plane mit Vision, aber nie statisch. Die technische Realität gehört für mich von Anfang an mit ins Konzept — nicht als Bremse, sondern als kreative Mitspielerin. Form und Funktion sind für mich keine Gegner, sondern Sparringspartner.',
  },
];

// Ausbildungs-Stationen für den dedizierten Block unter dem Werdegang.
// Reihenfolge: chronologisch absteigend (neueste zuerst).
const educationStations: EducationStation[] = [
  {
    period: 'Mai 2025 – 2026',
    title: 'CRM-Manager (IHK)',
    institution: 'ILS — Institut für Lernsysteme',
    description: 'Fernstudium · in Vorbereitung · Abschluss 2026',
  },
  {
    period: '2016 – 2018',
    title: 'Geprüfter Fachkaufmann für Marketing (IHK)',
    institution: 'IHK Schwarzwald-Baar-Heuberg',
    description: 'Berufsbegleitende Weiterbildung parallel zur Selbstständigkeit',
  },
  {
    period: '2004 – 2006',
    title: 'Staatlich geprüfter Informatiker für Multimedia',
    institution: 'SRH Heidelberg',
    description: 'Erstausbildung — technisches Fundament für die spätere Marketing-Karriere',
  },
];
---

<BaseLayout
  title="Über mich — Torsten Günter"
  description="Marketing- & E-Commerce-Manager mit technischer DNA. Mein Werdegang, meine Werte, mein Fokus auf CRM und KI-gestützte Customer Experience."
>

  <!--
    Spacing-Konvention (siehe skills.astro / kontakt.astro / Memory):
      • Page-Wrapper:  py-16 md:py-24 lg:py-32
      • Sektionen:     flex flex-col + Inline-Style row-gap: clamp(...)
      • Grids:         Inline-Style display:grid + repeat(auto-fit, minmax(...))
    Tailwind gap-* / grid-cols-* sind in diesem Setup unzuverlässig.
  -->
  <div class="py-16 md:py-24 lg:py-32">

    <div
      class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col"
      style="row-gap: clamp(2.5rem, 4vw, 4.5rem);"
    >

      <!-- ── 1. HERO (zweispaltig: Text + Foto-Stack mit Mini-Qualifikationen) ── -->
      <section>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: clamp(1.5rem, 4vw, 3rem); align-items: center;">

          <!-- LEFT: Text -->
          <div>
            <p class="flex items-center gap-2 text-sm text-text-secondary mb-5">
              <span class="w-2 h-2 bg-primary rounded-sm shrink-0" aria-hidden="true"></span>
              Über mich
            </p>
            <h1 class="font-serif text-4xl sm:text-5xl font-medium text-text-primary leading-tight mb-5">
              Hinter den Skills.
            </h1>
            <p class="text-lg text-text-secondary leading-relaxed" style="max-width: 440px;">
              Wer ich bin, wo ich herkomme — und warum die Schnittstelle zwischen Marketing und Tech mein Zuhause ist.
            </p>
          </div>

          <!-- RIGHT: Profil-Card (Akzentlinie, Foto, Separator, Eyebrow, Qualifikationen) -->
          <div class="flex justify-center">
            <article class="profile-card">

              <!-- Bronze-Akzentlinie (wie auf den Werte-Cards) -->
              <div class="profile-accent" aria-hidden="true"></div>

              <!--
                Foto-Container (Kreis, Bronze-Border, Bronze-Soft-BG als Platzhalter-Fläche).
                `overflow: hidden` sorgt dafür, dass `object-fit: cover` sauber im Kreis greift.
                aria-hidden nur, solange der TG-Initialen-Fallback aktiv ist.
              -->
              <div
                class="profile-photo"
                aria-hidden={hasRealPhoto ? undefined : 'true'}
              >
                {hasRealPhoto ? (
                  <Image
                    src={torstenImage}
                    alt="Torsten Günter"
                    width={220}
                    height={220}
                    loading="eager"
                    style="width: 100%; height: 100%; object-fit: cover; display: block;"
                  />
                ) : (
                  <span class="profile-initials">TG</span>
                )}
              </div>

              <!-- Subtiler Separator zwischen Foto und Text-Block -->
              <hr class="profile-separator" />

              <!-- Eyebrow „Profil auf einen Blick" mit Bronze-Punkt (::before) -->
              <p class="profile-eyebrow">Profil auf einen Blick</p>

              <!-- Quick-Facts: <strong> für Label, <span class="qual-note"> für Wert.
                   Klassen analog zur vormaligen Qualifikationen-Liste, damit Styling
                   konsistent bleibt. Ausbildungs-Details stehen jetzt im dedizierten
                   Ausbildungs-Block unterhalb des Werdegangs. -->
              <ul class="profile-quals">
                <li><strong>Erfahrung</strong><span class="qual-note">— 15+ Jahre Marketing &amp; Tech</span></li>
                <li><strong>Schwerpunkt</strong><span class="qual-note">— CRM · Customer Experience · KI-Automation</span></li>
                <li><strong>Standort</strong><span class="qual-note">— Süddeutschland · Remote möglich</span></li>
                <li><strong>Status</strong><span class="qual-note">— CRM-Manager (IHK), Abschluss 2026</span></li>
              </ul>

            </article>
          </div>

        </div>
      </section>

      <!-- ── 2. STORY-BLOCK ──────────────────────────────────────────── -->
      <section class="max-w-3xl mx-auto w-full">
        <p class="text-text-secondary" style="font-size: 17px; line-height: 1.7;">
          Meine Basis ist eine technische: ausgebildeter Informatiker für Multimedia, ursprünglich
          als Frontend-Entwickler unterwegs. Aber schnell wurde klar — die spannenderen Fragen
          liegen zwischen Code und Kunde. Seit über zehn Jahren bewege ich mich an dieser
          Schnittstelle, heute mit Fokus auf CRM und KI-gestützte Customer Experience.
        </p>
      </section>

      <!-- ── 3. WERTE-STATEMENTS (3 Cards) ───────────────────────────── -->
      <section>
        <p class="flex items-center gap-2 text-sm text-text-secondary mb-4">
          <span class="w-2 h-2 bg-primary rounded-sm shrink-0" aria-hidden="true"></span>
          Was mich antreibt
        </p>
        <h2 class="font-serif text-2xl sm:text-3xl font-medium text-text-primary mb-8">
          Drei Werte, die meine Arbeit prägen.
        </h2>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: clamp(1rem, 2vw, 1.5rem);">
          {values.map((value) => (
            <article class="value-card">
              <div class="w-8 h-[3px] bg-primary rounded-full mb-5" aria-hidden="true"></div>
              <h3 class="font-serif font-medium text-text-primary mb-3" style="font-size: 21px; line-height: 1.3;">
                {value.title}
              </h3>
              <p class="text-text-secondary" style="font-size: 14.5px; line-height: 1.65;">
                {value.body}
              </p>
            </article>
          ))}
        </div>
      </section>

      <!-- ── 4. WERDEGANGS-TIMELINE (5 Stationen, reverse chronologisch) ─ -->
      <section class="max-w-3xl mx-auto w-full">
        <p class="flex items-center gap-2 text-sm text-text-secondary mb-4">
          <span class="w-2 h-2 bg-primary rounded-sm shrink-0" aria-hidden="true"></span>
          Werdegang
        </p>
        <h2 class="font-serif text-2xl sm:text-3xl font-medium text-text-primary mb-8">
          Stationen meiner bisherigen Reise.
        </h2>

        <ol class="timeline">
          {stations.map((station) => (
            <li>
              <p class="station-period">{station.period}</p>
              <h3 class="station-title">{station.title}</h3>
              {station.company && (
                <p class="station-company">{station.company}</p>
              )}
              <p class="station-description">{station.description}</p>
              <ul class="bullet-list">
                {station.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </li>
          ))}
        </ol>
      </section>

      <!-- ── 5. AUSBILDUNGS-TIMELINE (3 Stationen, reverse chronologisch) ─ -->
      <section class="max-w-3xl mx-auto w-full">
        <p class="flex items-center gap-2 text-sm text-text-secondary mb-4">
          <span class="w-2 h-2 bg-primary rounded-sm shrink-0" aria-hidden="true"></span>
          Ausbildung
        </p>
        <h2 class="font-serif text-2xl sm:text-3xl font-medium text-text-primary mb-8">
          Formale Basis und Weiterbildung.
        </h2>

        <ol class="timeline">
          {educationStations.map((station) => (
            <li>
              <p class="station-period">{station.period}</p>
              <h3 class="station-title">{station.title}</h3>
              <p class="station-company">{station.institution}</p>
              <p class="station-description">{station.description}</p>
            </li>
          ))}
        </ol>
      </section>

      <!-- ── 6. CLOSING-CTA ──────────────────────────────────────────── -->
      <section>
        <div class="bg-background-soft rounded-lg text-center" style="padding: clamp(2.5rem, 5vw, 4rem) clamp(1.5rem, 4vw, 3rem);">
          <div class="max-w-md mx-auto">
            <h2 class="font-serif text-2xl sm:text-3xl font-medium text-text-primary mb-3">
              Klingt nach einem Match?
            </h2>
            <p class="text-text-secondary mb-8" style="font-size: 16.5px; line-height: 1.6;">
              Schreib mir gerne — ich freue mich auf den Austausch.
            </p>
            <a
              href="/kontakt"
              class="inline-flex items-center px-6 py-3 rounded-lg bg-primary text-white font-medium transition-all duration-200 hover:bg-primary-hover"
              style="text-decoration: none;"
            >
              Kontakt aufnehmen
            </a>
          </div>
        </div>
      </section>

    </div>
  </div>

</BaseLayout>

<style>
  /* ── Werte-Cards ───────────────────────────────────────────────────── */
  .value-card {
    background: #FFFFFF;
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.5rem;
    padding: 1.5rem 1.75rem;
    transition: transform 200ms ease, border-color 200ms ease;
  }
  .value-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-primary);
  }

  /* ── Timeline ──────────────────────────────────────────────────────── */
  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    row-gap: clamp(2rem, 4vw, 3rem);
  }

  .station-period {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }
  .station-title {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 500;
    color: var(--color-primary);
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }
  .station-company {
    font-size: 15px;
    color: var(--color-text-secondary);
    margin-bottom: 0.875rem;
  }
  .station-description {
    font-size: 15px;
    font-style: italic;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  /* ── Bullet-Liste mit Bronze-Punkten (Timeline) ────────────────────── */
  .bullet-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    row-gap: 0.5rem;
  }
  .bullet-list li {
    display: flex;
    column-gap: 0.625rem;
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--color-text-secondary);
  }
  .bullet-list li::before {
    content: '';
    flex-shrink: 0;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-primary);
    margin-top: 0.55rem;
  }

  /* ── Profil-Card (Hero, rechte Spalte) ───────────────────────────────── */
  .profile-card {
    background: #FFFFFF;
    border: 0.5px solid var(--color-border-subtle);
    border-radius: 12px;
    padding: 1.5rem;
    max-width: 420px;
    width: 100%;
    position: relative;
  }

  .profile-accent {
    width: 32px;
    height: 3px;
    background: var(--color-primary);
    border-radius: 9999px;
    margin: 0 auto 1rem;
  }

  .profile-photo {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    border: 1.5px solid var(--color-primary);
    background: var(--color-primary-soft);
    margin: 0 auto 1.125rem;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .profile-photo {
      width: 160px;
      height: 160px;
    }
  }

  .profile-initials {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 44px;
    color: var(--color-primary);
    line-height: 1;
  }

  .profile-separator {
    border: none;
    border-top: 0.5px solid var(--color-border-subtle);
    margin: 0 0 1rem;
  }

  .profile-eyebrow {
    display: flex;
    align-items: center;
    column-gap: 0.5rem;
    font-size: 11.5px;
    letter-spacing: 0.02em;
    color: var(--color-text-secondary);
    margin: 0 0 0.625rem;
  }
  .profile-eyebrow::before {
    content: '';
    width: 5px;
    height: 5px;
    background: var(--color-primary);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .profile-quals {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    row-gap: 0.5rem;
  }
  .profile-quals li {
    font-size: 12.5px;
    line-height: 1.45;
  }
  .profile-quals strong {
    font-weight: 500;
    color: var(--color-text-primary);
  }
  .qual-note {
    font-weight: 400;
    color: var(--color-text-secondary);
    margin-left: 0.25rem;
  }
</style>
