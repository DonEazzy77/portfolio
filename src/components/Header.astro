---
const navLinks = [
  { href: '/',          label: 'Start' },
  { href: '/ueber-mich', label: 'Über mich' },
  { href: '/skills',    label: 'Skills' },
  { href: '/kontakt',   label: 'Kontakt' },
];

const currentPath = Astro.url.pathname;

// Exaktes Match für "/" – sonst würde jede Seite als aktiv gelten
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="sticky top-0 z-50 bg-background/95 backdrop-blur-sm border-b border-border-subtle">
  <nav class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <span class="bg-primary text-white font-semibold text-sm rounded-lg w-9 h-9 flex items-center justify-center shrink-0">
        TG
      </span>
      <span class="font-serif text-lg text-text-primary group-hover:text-primary transition-colors">
        Torsten Günter
      </span>
    </a>

    <!-- Desktop-Navigation -->
    <div class="hidden md:flex items-center gap-6">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'text-sm font-medium transition-colors',
            isActive(href)
              ? 'text-primary'
              : 'text-text-secondary hover:text-text-primary',
          ]}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          {label}
        </a>
      ))}

      <!-- Sprachumschalter – Platzhalter, noch nicht funktional -->
      <span
        class="text-sm text-text-secondary border-l border-border-subtle pl-5 ml-1 select-none opacity-50 cursor-not-allowed"
        title="Sprachumschalter – folgt demnächst"
      >
        DE / EN
      </span>
    </div>

    <!-- Mobile: Burger-Button -->
    <button
      id="burger-btn"
      class="md:hidden p-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-background-soft transition-colors"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <!-- Hamburger-Icon (sichtbar wenn Menü zu) -->
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <!-- Schließen-Icon (sichtbar wenn Menü offen) -->
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile-Menü (md:hidden hält es auf Desktop immer versteckt) -->
  <div id="mobile-nav" class="hidden md:hidden border-t border-border-subtle bg-background px-4 py-3 space-y-1">
    {navLinks.map(({ href, label }) => (
      <a
        href={href}
        class:list={[
          'block px-3 py-2 rounded-md text-sm font-medium transition-colors',
          isActive(href)
            ? 'text-primary bg-primary-soft'
            : 'text-text-secondary hover:text-text-primary hover:bg-background-soft',
        ]}
        aria-current={isActive(href) ? 'page' : undefined}
      >
        {label}
      </a>
    ))}

    <div class="px-3 pt-3 mt-1 border-t border-border-subtle">
      <span class="text-sm text-text-secondary opacity-50 cursor-not-allowed select-none">
        DE / EN
      </span>
    </div>
  </div>
</header>

<script>
  const burger  = document.getElementById('burger-btn');
  const menu    = document.getElementById('mobile-nav');
  const iconOpen  = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  burger?.addEventListener('click', () => {
    // toggle('hidden') gibt true zurück wenn die Klasse HINZUGEFÜGT wurde (→ Menü jetzt zu)
    const menuHidden = menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !menuHidden);
    iconClose?.classList.toggle('hidden', menuHidden ?? true);
    burger?.setAttribute('aria-expanded', String(!menuHidden));
  });
</script>
